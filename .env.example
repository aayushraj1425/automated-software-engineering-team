# ASEP environment — copy to `.env` at the repo root.
# One file drives compose defaults, the engine (pydantic-settings), and the
# web app (loaded via next.config.ts). Never commit `.env`.

# ── LLM providers (set at least one key, or LLM_FAKE=1 to run without any) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Deterministic canned responses for tests/CI/offline dev — no key needed
LLM_FAKE=0

# Model tiers (LiteLLM ids: provider/model). Any LiteLLM-supported model works.
MODEL_PLANNER=anthropic/claude-opus-4-8
MODEL_CODER=anthropic/claude-sonnet-4-6
MODEL_CHEAP=anthropic/claude-haiku-4-5

# ── Data stores (compose defaults) ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://asep:asep@localhost:5432/asep
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=asep-dev

# ── Auth (web / better-auth) ────────────────────────────────────────────────
BETTER_AUTH_SECRET=dev-only-secret-change-me-0000000000
BETTER_AUTH_URL=http://localhost:3000
# OAuth providers activate automatically when credentials are set
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Web ↔ Engine service auth (HS256 JWT, BFF-signed) ───────────────────────
ENGINE_URL=http://localhost:8000
ENGINE_SERVICE_SECRET=dev-only-service-secret-change-me-00

# ── Engine runtime ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENGINE_CORS_ORIGINS=http://localhost:3000
