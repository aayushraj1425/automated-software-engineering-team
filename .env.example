# ASEP environment — copy to `.env` at the repo root.
# One file drives compose defaults, the engine (pydantic-settings), and the
# web app (loaded via next.config.ts). Never commit `.env`.

# ── LLM providers (set at least one key, or LLM_FAKE=1 to run without any) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Deterministic canned responses for tests/CI/offline dev — no key needed
LLM_FAKE=0

# Model tiers (LiteLLM ids: provider/model). Any LiteLLM-supported model works.
MODEL_PLANNER=anthropic/claude-opus-4-8
MODEL_CODER=anthropic/claude-sonnet-4-6
MODEL_CHEAP=anthropic/claude-haiku-4-5
# Repository indexing (Phase 2) — must produce 768-number vectors
MODEL_EMBEDDING=gemini/text-embedding-004

# ── Data stores (compose defaults) ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://asep:asep@localhost:5433/asep
# Privilege separation: user-pinned API sessions connect as the non-owner
# asep_api role (created by postgres-init on fresh volumes). Empty = one role.
DATABASE_URL_API=postgresql+psycopg://asep_api:asep_api@localhost:5433/asep
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=asep-dev

# ── Auth (web / better-auth) ────────────────────────────────────────────────
BETTER_AUTH_SECRET=dev-only-secret-change-me-0000000000
BETTER_AUTH_URL=http://localhost:3000
# OAuth providers activate automatically when credentials are set
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Web ↔ Engine service auth (HS256 JWT, BFF-signed) ───────────────────────
ENGINE_URL=http://localhost:8000
ENGINE_SERVICE_SECRET=dev-only-service-secret-change-me-00
# AES-GCM key (base64, 32 bytes) for secrets at rest, e.g. bring-your-own
# provider keys (docs/architecture/PROVIDER_KEYS.md). Empty derives a dev key
# from ENGINE_SERVICE_SECRET — set a dedicated value in production.
ENGINE_ENCRYPTION_KEY=

# ── Engine runtime ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENGINE_CORS_ORIGINS=http://localhost:3000
# Personal access token (repo scope): pushes run branches and opens pull requests,
# and (for the webhook reviewer) reads PR diffs and posts review comments
GITHUB_TOKEN=
# Shared secret GitHub signs webhooks with (X-Hub-Signature-256). Empty rejects
# all webhook calls — set it to enable the pull-request reviewer.
GITHUB_WEBHOOK_SECRET=
# Resume runs a restart interrupted (docs/architecture/RUN_RECOVERY.md)
RUN_RECOVERY_ENABLED=1
# Where runs execute: "inline" (background task in the API process) or "arq"
# (Redis queue + a worker: `uv run arq engine.worker.WorkerSettings`).
# Design note: docs/architecture/BACKGROUND_WORKER.md
RUN_QUEUE=inline

# ── Sandbox (Docker) ────────────────────────────────────────────────────────
# Run the workspace's tests in a disposable container before the pull request.
# Needs Docker Desktop running; skipped (and recorded) when it is not.
SANDBOX_ENABLED=1
# Strict mode: fail the run instead of skipping when Docker is not available
SANDBOX_REQUIRED=0
# Time limit per phase (dependency install, then tests), in seconds
SANDBOX_TIMEOUT_SECONDS=300
# QA agent: fix-and-retry cycles when the sandbox tests fail, before failing the run
QA_MAX_ATTEMPTS=2

# ── Observability (OpenTelemetry — ADR-0010, Phase 7) ───────────────────────
# Spans and metrics are no-ops until enabled; requests, LLM calls, and agent
# runs are traced. Design note: docs/architecture/PRODUCTION_HARDENING.md
OTEL_ENABLED=0
# An OTLP-over-HTTP collector, e.g. http://localhost:4318 — empty keeps
# telemetry in-process only
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=asep-engine

# ── Rate limiting (Phase 7) ─────────────────────────────────────────────────
# Per-caller token bucket on the engine API: 0 disables (the default); the
# bucket holds RATE_LIMIT_BURST tokens refilling at RATE_LIMIT_PER_MINUTE/60
# per second. Design note: docs/architecture/RATE_LIMITING.md
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=30
# Share one bucket across engine replicas via Redis (else it is per-replica,
# so the effective limit is RATE_LIMIT_PER_MINUTE × replicas). A Redis outage
# degrades back to per-replica, never to a hard dependency. Set 1 in production.
RATE_LIMIT_SHARED=0

# ── Backups (Phase 7) ──────────────────────────────────────────────────────────
# Nightly pg_dump from the arq worker when enabled; the CLI works regardless:
#   uv run python -m engine.backup create
# Design note: docs/architecture/BACKUPS_AND_RECOVERY.md
# Runbook: docs/runbooks/DISASTER_RECOVERY.md
BACKUP_ENABLED=0
# Where dump files land (local disk — ship them off-host in production)
BACKUP_DIR=.backups
# How many dumps to keep; older ones are pruned after each successful backup
BACKUP_RETENTION=14
# Directory holding pg_dump/pg_restore when they are not on PATH, e.g.
# C:\Program Files\PostgreSQL\18\bin — empty tries PATH, then that install dir
PG_BIN_DIR=
